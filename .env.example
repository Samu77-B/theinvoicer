# Copy to .env for local development (never commit .env)

SECRET_KEY=generate-a-long-random-string
FLASK_DEBUG=true

# Local: omit DATABASE_URL to use SQLite at instance/invoices.db
# Railway: add PostgreSQL in the project; Railway sets DATABASE_URL on this service (reference the variable).
# DATABASE_URL=postgresql://...

# Optional: store generated PDFs on a mounted path (only if you use server-side PDF files)
# DATA_DIR=/data

# Resend (https://resend.com)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Invoices <onboarding@resend.dev>
